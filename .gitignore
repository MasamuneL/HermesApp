.pytest_cache/
.coverage
htmlcov/

# Bases de datos locales (SQLite del prototipo HermesAgent)
*.sqlite
*.db

# Logs
*.log

# Node (por si el frontend usa npm en el futuro)
node_modules/

# IDEs
.vscode/
.idea/
*.swp

# Sistema operativo
.DS_Store
Thumbs.db

