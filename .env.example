# ============================================================
#  HERMES APP — Variables de entorno
#  Copia este archivo a .env y llena los valores reales.
#  NUNCA subas el .env al repo (ya está en .gitignore).
# ============================================================

# ------------------------------------------------------------
# PostgreSQL
# Dennis te dará la URL de producción.
# Para desarrollo local usa docker-compose.
# ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://hermes_user:password123@localhost:5432/hermes_db

# ------------------------------------------------------------
# Redis
# Dennis te dará la URL de producción.
# Para desarrollo local usa docker-compose.
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# Google Gemini API
# Obtén tu API Key en: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=tu_api_key_aqui

# ------------------------------------------------------------
# Firebase Admin SDK
# Descarga el archivo de credenciales desde Firebase Console:
#   Configuración del proyecto → Cuentas de servicio → Generar clave privada
# Guarda el archivo como firebase-credentials.json en la raíz del backend.
# NUNCA subas este archivo al repo.
# ------------------------------------------------------------
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
