# ============================================================
#  HERMES APP — Variables de entorno
#  Copia este archivo a .env y llena los valores reales.
#  NUNCA subas el .env al repo (ya está en .gitignore).
# ============================================================

# ------------------------------------------------------------
# PostgreSQL
# Dennis te dará la URL de producción.
# Para desarrollo local usa docker-compose.
# ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://hermes_user:password123@postgres:5432/hermes

# ------------------------------------------------------------
# Redis
# Dennis te dará la URL de producción.
# Para desarrollo local usa docker-compose.
# ------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------
# Google Gemini API
# Obtén tu API Key en: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=tu_api_key_aqui

# ------------------------------------------------------------
# Google OAuth — Client ID (público, va también en el frontend)
# Crear en: Google Cloud Console → APIs & Services → Credentials
# → Create Credentials → OAuth 2.0 Client ID → Web application
# Authorized JavaScript origins: http://localhost + URL de producción
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=486932937666-23r90cvcs0l5rib6imbk7h9r5r4miu2a.apps.googleusercontent.com

# ------------------------------------------------------------
# Google Calendar API
# El access token lo manda el frontend en Authorization: Bearer <token>
# El mismo token de auth tiene scope de calendario — no se necesita
# header X-Google-Token separado.
# ------------------------------------------------------------
